{
  "name": "subtrack",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@subtrack/db",
    "db:migrate": "turbo run db:migrate --filter=@subtrack/db",
    "db:studio": "turbo run db:studio --filter=@subtrack/db",
    "db:push": "turbo run db:push --filter=@subtrack/db"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
